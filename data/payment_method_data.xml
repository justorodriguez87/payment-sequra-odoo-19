<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment_method_sequra" model="payment.method">
        <field name="name">seQura</field>
        <field name="code">sequra</field>
        <field name="sequence">1000</field>
        <field name="active">False</field>
        <field name="image" type="base64" file="payment_sequra/static/src/img/sequra_icon.png"/>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="supported_country_ids"
               eval="[Command.set([
                         ref('base.es'),
                         ref('base.pt'),
                         ref('base.fr'),
                         ref('base.it'),
                     ])]"
        />
        <field name="supported_currency_ids" eval="[Command.set([ref('base.EUR')])]"/>
    </record>

</odoo>
