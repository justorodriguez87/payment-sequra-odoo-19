<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_sequra" model="ir.ui.view">
        <field name="name">product.template.form.sequra</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']/group[@name='sale']" position="inside">
                <group name="sequra" string="seQura" invisible="not sale_ok">
                    <field name="sequra_excluded"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
